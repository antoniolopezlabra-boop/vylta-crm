# ══════════════════════════════════════════════════════════════════════
# VYLTA CRM — Variables de entorno
# ══════════════════════════════════════════════════════════════════════
# Copia este archivo a .env.local y llena los valores reales.
# NUNCA commitees .env.local — está en .gitignore.

# ── Supabase ──
# Las mismas credenciales que la app móvil VYLTA.
# Encuéntralas en: https://supabase.com/dashboard/project/nhjmwmkaduiaifgztymi/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://nhjmwmkaduiaifgztymi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ── Service Role Key (SOLO server) ──
# Necesaria para crear/invitar administradores desde el panel
# (/api/admin/create). Tiene permisos totales: NUNCA la pongas con el
# prefijo NEXT_PUBLIC_ y NUNCA la expongas al cliente.
# La encuentras en el mismo panel de API de Supabase (service_role secret).
# En producción, agrégala también en Vercel → Project Settings → Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ── App URL (opcional, para metadata y redirect de invitaciones) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
